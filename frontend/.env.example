VITE_API_URL=http://localhost:8000/api
# Must match backend INTERNAL_KEY (online order → POS stock sync)
VITE_INTERNAL_KEY=
VITE_API_TIMEOUT=30000
VITE_LOG_API_REQUESTS=false
# Production example: VITE_API_URL=https://api.yoursite.com/api
# WhatsApp order confirmations (digits only, e.g. 254724494089)
VITE_WHATSAPP_NUMBER=254724494089
# M-Pesa Pay Bill (ELIJAY'S Men's Wear: 303030 / ELJY#)
VITE_MPESA_PAYBILL=303030
VITE_MPESA_ACCOUNT=ELJY#
# Optional Buy Goods till — only used when pay bill is not set
VITE_MPESA_TILL=
